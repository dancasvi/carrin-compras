generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model markets {
  id           Int          @id @default(autoincrement())
  document     String       @unique @db.VarChar(20)
  name         String       @db.VarChar(100)
  address      String?
  number       String?      @db.VarChar(10)
  neighborhood String?      @db.VarChar(50)
  city         String?      @db.VarChar(50)
  state        String?      @db.VarChar(2)
  country      String?      @default("Brasil") @db.VarChar(50)
  is_active    Boolean?     @default(true)
  created_at   DateTime?    @default(now()) @db.Timestamptz(6)
  updated_at   DateTime?    @default(now()) @updatedAt @db.Timestamptz(6)
  updated_by   Int?
  shop_lists   shop_lists[]
}

model product_brand {
  id               Int               @id @default(autoincrement())
  name             String            @db.VarChar(100)
  category_id      Int?
  logo_url         String?
  is_active        Boolean?          @default(true)
  created_at       DateTime?         @default(now()) @db.Timestamptz(6)
  updated_at       DateTime?         @default(now()) @updatedAt @db.Timestamptz(6)
  updated_by       Int?
  product_category product_category? @relation(fields: [category_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  products         products[]
}

model product_category {
  id            Int             @id @default(autoincrement())
  name          String          @db.VarChar(100)
  is_active     Boolean?        @default(true)
  created_at    DateTime?       @default(now()) @db.Timestamptz(6)
  updated_at    DateTime?       @default(now()) @db.Timestamptz(6)
  updated_by    Int?
  product_brand product_brand[]
}

model products {
  id             Int              @id @default(autoincrement())
  name           String           @db.VarChar(150)
  brand_id       Int?
  unit           String?          @db.VarChar(10)
  amount         Decimal?         @db.Decimal(10, 2)
  is_active      Boolean?         @default(true)
  created_at     DateTime?        @default(now()) @db.Timestamptz(6)
  updated_at     DateTime?        @default(now()) @db.Timestamptz(6)
  updated_by     Int?
  product_brand  product_brand?   @relation(fields: [brand_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  shop_list_item shop_list_item[]
}

model shop_list_item {
  id           Int         @id @default(autoincrement())
  shop_list_id Int?
  product_id   Int?
  amount       Decimal     @db.Decimal(10, 2)
  price        Decimal     @db.Decimal(10, 2)
  products     products?   @relation(fields: [product_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  shop_lists   shop_lists? @relation(fields: [shop_list_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model shop_lists {
  id             Int              @id @default(autoincrement())
  expected_date  DateTime?        @db.Date
  performed_date DateTime?        @db.Date
  market_id      Int?
  user_id        Int?
  shop_list_item shop_list_item[]
  markets        markets?         @relation(fields: [market_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users          users?           @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model users {
  id            Int          @id @default(autoincrement())
  username      String       @unique @db.VarChar(50)
  password      String
  name          String       @db.VarChar(100)
  email_address String       @unique @db.VarChar(100)
  phone_number  String?      @db.VarChar(20)
  avatar_url    String?
  birth_date    DateTime?    @db.Date
  is_active     Boolean?     @default(true)
  created_at    DateTime?    @default(now()) @db.Timestamptz(6)
  updated_at    DateTime?    @default(now()) @updatedAt @db.Timestamptz(6)
  updated_by    Int?
  shop_lists    shop_lists[]
}
